#!name = Netflix 最近双官方字幕
#!desc = 当前官方字幕在上、上次选择字幕在下；收紧相近边界，保留真实换句、独立 CC 与硬字幕翻译
#!author = Minis
#!homepage = https://github.com/lukeli17/Netflix-Shadowrocket
#!version = 1.6

[Script]
Netflix Official Dual v1.6 = type=http-response, pattern=^https?:\/\/[^/]+\.oca\.nflxvideo\.net\/.*, requires-body=1, script-path=https://raw.githubusercontent.com/lukeli17/Netflix-Shadowrocket/main/netflix-dual-subtitles.js?v=1.6, timeout=10

[MITM]
hostname = %APPEND% *.oca.nflxvideo.net
tcp-connection = true
